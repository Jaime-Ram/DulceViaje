{
  "expo": {
    "name": "Bondivideo",
    "slug": "bondivideo",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "primaryColor": "#0055B3",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0055B3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bondivideo.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Bondivideo gebruikt je locatie om nabijgelegen bushaltes te tonen en je reis te plannen.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Bondivideo gebruikt je locatie om nabijgelegen bushaltes te tonen en je reis te plannen.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0055B3"
      },
      "package": "com.bondivideo.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Bondivideo gebruikt je locatie om nabijgelegen bushaltes te tonen en je reis te plannen.",
          "locationWhenInUsePermission": "Bondivideo gebruikt je locatie om nabijgelegen bushaltes te tonen en je reis te plannen."
        }
      ]
    ],
    "scheme": "bondivideo",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://jaime-ram.github.io/Bondivideo/privacy",
      "eas": {
        "projectId": "VUL_HIER_JE_EAS_PROJECT_ID_IN"
      }
    }
  }
}
