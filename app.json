{
  "expo": {
    "name": "Bondivideo",
    "slug": "bondivideo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0055B3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bondivideo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0055B3"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bondivideo.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Bondivideo uses your location to show nearby bus stops.",
          "locationWhenInUsePermission": "Bondivideo uses your location to show nearby bus stops."
        }
      ]
    ],
    "scheme": "bondivideo",
    "experiments": {
      "typedRoutes": true
    }
  }
}